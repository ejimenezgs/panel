rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /catalogProductOverrides/{productId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    match /catalogSettings/{documentId} {
      allow read, write: if request.auth != null;
    }

    match /contactMessages/{messageId} {
      // Los formularios publicos solo pueden crear mensajes.
      allow create: if
        request.resource.data.keys().hasOnly([
          'name',
          'email',
          'phone',
          'message',
          'source',
          'status',
          'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.message is string
        && request.resource.data.source is string
        && request.resource.data.status is string
        && request.resource.data.source in [
          'casaglick.com',
          'shop.casaglick.com'
        ]
        && request.resource.data.status == 'unread'
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 120
        && request.resource.data.email.size() <= 200
        && request.resource.data.phone.size() <= 30
        && request.resource.data.message.size() >= 2
        && request.resource.data.message.size() <= 3000;

      // Cualquier usuario autenticado del panel puede ver, editar o eliminar mensajes.
      allow read, update, delete: if request.auth != null;
    }
    match /orders/{orderId} {
      allow create: if request.resource.data.keys().hasAll(['folio','status','customer','items','total','createdAt'])
        && request.resource.data.status == 'Nueva'
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 50;
      allow read, update, delete: if request.auth != null;
    }
  }
}
