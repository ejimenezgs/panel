rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /catalogProductOverrides/{productId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    match /catalogSettings/{documentId} {
      allow read, write: if request.auth != null;
    }

    match /contactMessages/{messageId} {
      allow create: if request.resource.data.keys().hasAll(['name','message','source','status','createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 5000
        && request.resource.data.source in ['casaglick.com','shop.casaglick.com']
        && request.resource.data.status == 'unread';
      allow read, update, delete: if request.auth != null;
    }
    match /orders/{orderId} {
      allow create: if request.resource.data.keys().hasAll(['folio','status','customer','items','total','createdAt'])
        && request.resource.data.status == 'Nueva'
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 50;
      allow read, update, delete: if request.auth != null;
    }
  }
}
